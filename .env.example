# =============================================================================
# Forms app – environment variables
# =============================================================================
# Copy this file to .env.local and adjust for your environment.
# Defaults below point to *.carteracredit.workers.dev (dev Workers).
# =============================================================================

# -----------------------------------------------------------------------------
# Workflow service (workflow-svc)
# -----------------------------------------------------------------------------
# Base URL for the workflow backend API (forms, workflows, flags, etc.).
# Used by: forms API client (api/config.ts).
NEXT_PUBLIC_WORKFLOW_SERVICE_URL=https://workflow-svc.carteracredit.workers.dev

# -----------------------------------------------------------------------------
# Auth service (auth-svc)
# -----------------------------------------------------------------------------
# Base URL for the auth backend API (get-session, token, jwks).
# Used by: middleware (session validation), auth config, getJwt, authClient.
NEXT_PUBLIC_AUTH_SERVICE_URL=https://auth-svc.carteracredit.workers.dev

# -----------------------------------------------------------------------------
# Auth app (auth frontend)
# -----------------------------------------------------------------------------
# Base URL for the auth frontend (login, signup). Users are redirected here
# when unauthenticated or when obtaining a JWT.
# Used by: middleware (redirect to login), auth config.
NEXT_PUBLIC_AUTH_APP_URL=https://auth.carteracredit.workers.dev

# -----------------------------------------------------------------------------
# Cases service (cases-svc) — card tokenization proxy
# -----------------------------------------------------------------------------
# Base URL only (no secrets). Used by: POST /api/cards/tokenize → forwards JWT.
NEXT_PUBLIC_CASES_SERVICE_URL=https://cases-svc.carteracredit.workers.dev

# -----------------------------------------------------------------------------
# Address enrichment (server-only — set in Cloudflare Worker secrets / .env.local)
# -----------------------------------------------------------------------------
# USPS APIs v3 OAuth2 (client credentials). Never expose as NEXT_PUBLIC_*.
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# Google Places API (New) — restrict key by HTTP referrer / host in GCP console.
GOOGLE_PLACES_API_KEY=
